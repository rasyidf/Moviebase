<Window
    x:Class="Moviebase.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Moviebase">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Width="24" Height="24" CornerRadius="4"
                    Background="{ThemeResource AccentFillColorDefaultBrush}" VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock Text="M" FontSize="13" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" />
            </Border>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Moviebase" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                <TextBlock x:Name="PathText" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="440" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <Grid Grid.Column="0" Padding="16,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Toolbar: grouped by workflow step -->
                <CommandBar Grid.Row="0" DefaultLabelPosition="Right" IsOpen="False"
                            HorizontalAlignment="Left" Background="Transparent">
                    <!-- Step 1: Load -->
                    <AppBarButton Label="Add Folder" Click="OpenFolder_Click" AccessKey="O"
                                  ToolTipService.ToolTip="Add a movie folder to the library">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE8DA;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="Import Files" Click="ImportFiles_Click"
                                  ToolTipService.ToolTip="Scan Downloads/Videos for importable movies">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE8B5;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <!-- Step 2: Enrich -->
                    <AppBarButton x:Name="FetchBtn" Label="Look Up" Click="Fetch_Click" AccessKey="F"
                                  ToolTipService.ToolTip="Look up movie info from TMDB">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE721;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Name="PosterBtn" Label="Get Posters" Click="Posters_Click"
                                  ToolTipService.ToolTip="Download poster images to each folder">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE91B;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <!-- Step 3: Organize -->
                    <AppBarButton x:Name="RenameBtn" Label="Rename All" Click="Rename_Click"
                                  ToolTipService.ToolTip="Rename files and folders using the pattern in settings">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE8AC;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <CommandBar.SecondaryCommands>
                        <AppBarButton Label="Detect Collections" Click="DetectCollections_Click">
                            <AppBarButton.Icon><FontIcon Glyph="&#xE1D3;" /></AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton Label="Generate NFO files" Click="GenerateNfo_Click">
                            <AppBarButton.Icon><FontIcon Glyph="&#xE9F9;" /></AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton Label="Set Folder Thumbnails" Click="SetThumbnails_Click">
                            <AppBarButton.Icon><FontIcon Glyph="&#xEB9F;" /></AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarSeparator />
                        <AppBarButton Label="Export CSV" Click="ExportCsv_Click" Icon="Download" />
                        <AppBarButton Label="Export JSON" Click="ExportJson_Click" Icon="Download" />
                        <AppBarSeparator />
                        <AppBarButton Label="Settings" Click="Settings_Click" Icon="Setting" />
                    </CommandBar.SecondaryCommands>
                </CommandBar>

                <!-- Search/Filter + Sort -->
                <Grid Grid.Row="1" Margin="0,0,0,8" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <AutoSuggestBox x:Name="SearchBox" PlaceholderText="Filter movies..."
                                    QueryIcon="Find" TextChanged="SearchBox_TextChanged" VerticalAlignment="Top" />
                    <ComboBox x:Name="SortBox" Grid.Column="1" Width="150" VerticalAlignment="Top"
                              SelectionChanged="SortBox_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="Title (A–Z)" />
                        <ComboBoxItem Content="Year (newest)" />
                        <ComboBoxItem Content="Date Added" />
                        <ComboBoxItem Content="Size (largest)" />
                    </ComboBox>
                </Grid>

                <!-- Movie List Area -->
                <ScrollViewer Grid.Row="2" Padding="0,0,0,8">
                    <StackPanel x:Name="MovieListPanel" Spacing="0">
                        <!-- Empty state -->
                        <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Spacing="12" Padding="0,80">
                            <FontIcon Glyph="&#xE8DA;" FontSize="40" HorizontalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="Scan a folder to get started"
                                       HorizontalAlignment="Center" FontSize="14"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="Moviebase detects titles, quality, and series from filenames"
                                       HorizontalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Right: Detail Panel -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8,0,0,8" Padding="16,16" Margin="0,0,0,0">
                <Grid>
                    <StackPanel x:Name="DetailEmpty" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Spacing="8" Opacity="0.5">
                        <FontIcon Glyph="&#xE8B9;" FontSize="32" HorizontalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="Select a movie" HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>

                    <Grid x:Name="DetailPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Top: Poster + Key Info side by side -->
                        <Grid Grid.Row="0" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="6" Width="100" Height="150"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Image x:Name="PosterImage" Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Top">
                                <TextBlock x:Name="TitleText" Style="{StaticResource BodyStrongTextBlockStyle}"
                                           TextWrapping="Wrap" MaxLines="3" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="YearText" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="GenreText" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock x:Name="SeriesText" FontSize="11"
                                           Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                <TextBlock x:Name="ImdbText" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <HyperlinkButton x:Name="ImdbLink" Content="Open in IMDB" FontSize="11"
                                                     Padding="0" Visibility="Collapsed" />
                                    <HyperlinkButton x:Name="TmdbLink" Content="Open in TMDB" FontSize="11"
                                                     Padding="0" Visibility="Collapsed" />
                                </StackPanel>
                                <TextBlock x:Name="QualityText" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </Grid>

                        <!-- Middle: Plot (scrollable if needed) -->
                        <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="PlotText" TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </ScrollViewer>

                        <!-- Bottom: File info -->
                        <TextBlock x:Name="FileText" Grid.Row="2" FontSize="11" Margin="0,8,0,0"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis" IsTextSelectionEnabled="True" />
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <!-- Status Bar -->
        <Grid Grid.Row="2" Padding="16,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Height="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="MovieCountText" Text="" FontSize="12" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,16,0" />
            <TextBlock x:Name="StatusText" Grid.Column="1" Text="Ready" FontSize="12" VerticalAlignment="Center" />
            <ProgressBar x:Name="ProgressBar" Grid.Column="2" Width="160" Visibility="Collapsed" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
