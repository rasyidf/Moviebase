<Window
    x:Class="Moviebase.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Moviebase">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <FontIcon Glyph="&#xE8B7;" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Moviebase" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                <TextBlock x:Name="PathText" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="440" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <Grid Grid.Column="0" Padding="16,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Toolbar: grouped by workflow step -->
                <CommandBar Grid.Row="0" DefaultLabelPosition="Right" IsOpen="False"
                            HorizontalAlignment="Left" Background="Transparent">
                    <!-- Step 1: Load -->
                    <AppBarButton Label="Scan Folder" Click="OpenFolder_Click" AccessKey="O"
                                  ToolTipService.ToolTip="Open a movie folder to scan (Ctrl+O)">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE8DA;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <!-- Step 2: Enrich -->
                    <AppBarButton x:Name="FetchBtn" Label="Look Up" Click="Fetch_Click" AccessKey="F"
                                  ToolTipService.ToolTip="Look up movie info from TMDB">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE721;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Name="PosterBtn" Label="Get Posters" Click="Posters_Click"
                                  ToolTipService.ToolTip="Download poster images to each folder">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE91B;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <!-- Step 3: Organize -->
                    <AppBarButton x:Name="RenameBtn" Label="Rename All" Click="Rename_Click"
                                  ToolTipService.ToolTip="Rename files and folders using the pattern in settings">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE8AC;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <CommandBar.SecondaryCommands>
                        <AppBarButton Label="Settings" Click="Settings_Click" Icon="Setting" />
                    </CommandBar.SecondaryCommands>
                </CommandBar>

                <!-- Movie List Area -->
                <ScrollViewer Grid.Row="1" Padding="0,0,0,8">
                    <StackPanel x:Name="MovieListPanel" Spacing="0">
                        <!-- Empty state -->
                        <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Spacing="12" Padding="0,80">
                            <FontIcon Glyph="&#xE8DA;" FontSize="40" HorizontalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="Scan a folder to get started"
                                       HorizontalAlignment="Center" FontSize="14"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="Moviebase detects titles, quality, and series from filenames"
                                       HorizontalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Right: Detail Panel -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8,0,0,8" Padding="20,16" Margin="0,0,0,0">
                <ScrollViewer>
                    <Grid>
                        <StackPanel x:Name="DetailEmpty" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Spacing="8" Opacity="0.5">
                            <FontIcon Glyph="&#xE8B9;" FontSize="32" HorizontalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="Select a movie" HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>

                        <StackPanel x:Name="DetailPanel" Visibility="Collapsed" Spacing="16">
                            <Image x:Name="PosterImage" MaxHeight="280" Stretch="Uniform"
                                   HorizontalAlignment="Center" />
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="TitleText" Style="{StaticResource SubtitleTextBlockStyle}"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock x:Name="YearText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="GenreText" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock x:Name="SeriesText" FontSize="12"
                                           Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                <TextBlock x:Name="ImdbText" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" />
                            </StackPanel>
                            <TextBlock x:Name="PlotText" TextWrapping="Wrap" MaxLines="10"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="QualityText" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="FileText" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextTrimming="CharacterEllipsis" IsTextSelectionEnabled="True" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

            <!-- Settings Overlay -->
            <Border x:Name="SettingsPanel" Grid.Column="1" Visibility="Collapsed"
                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                    CornerRadius="8,0,0,8" Padding="24,20">
                <ScrollViewer>
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE713;" FontSize="18" />
                            <TextBlock Text="Settings" Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                        <TextBox x:Name="ApiKeyBox" Header="TMDB API Key" PlaceholderText="Your API key from themoviedb.org" />
                        <TextBox x:Name="ExtensionsBox" Header="File Extensions" PlaceholderText=".mp4;.mkv;.avi" />
                        <TextBox x:Name="FilePatternBox" Header="File Rename Pattern" PlaceholderText="{}{Title} ({Year})" />
                        <TextBox x:Name="FolderPatternBox" Header="Folder Rename Pattern" PlaceholderText="{}{Title} ({Year})" />
                        <ToggleSwitch x:Name="SwapTheToggle" Header="Move 'The' to end" OnContent="Yes" OffContent="No" />
                        <Button Content="Save &amp; Close" Click="SaveSettings_Click"
                                Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Grid Grid.Row="2" Padding="16,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Height="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="MovieCountText" Text="" FontSize="12" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,16,0" />
            <TextBlock x:Name="StatusText" Grid.Column="1" Text="Ready" FontSize="12" VerticalAlignment="Center" />
            <ProgressBar x:Name="ProgressBar" Grid.Column="2" Width="160" Visibility="Collapsed" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
