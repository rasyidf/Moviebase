<ContentDialog
    x:Class="Moviebase.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    FullSizeDesired="True">

    <Grid Width="640" Height="480">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Nav -->
        <ListView x:Name="NavList" Grid.Column="0" SelectionMode="Single"
                  SelectionChanged="NavList_SelectionChanged"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                  Padding="4" CornerRadius="8,0,0,8">
            <ListViewItem Tag="Library" IsSelected="True">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE8B7;" FontSize="16" />
                    <TextBlock Text="Library" VerticalAlignment="Center" />
                </StackPanel>
            </ListViewItem>
            <ListViewItem Tag="TMDB">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE721;" FontSize="16" />
                    <TextBlock Text="TMDB" VerticalAlignment="Center" />
                </StackPanel>
            </ListViewItem>
            <ListViewItem Tag="Rename">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE8AC;" FontSize="16" />
                    <TextBlock Text="Rename" VerticalAlignment="Center" />
                </StackPanel>
            </ListViewItem>
            <ListViewItem Tag="About">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE946;" FontSize="16" />
                    <TextBlock Text="About" VerticalAlignment="Center" />
                </StackPanel>
            </ListViewItem>
        </ListView>

        <!-- Content Pages -->
        <ScrollViewer Grid.Column="1" Padding="20,12">
            <Grid>
                <!-- Library Page -->
                <StackPanel x:Name="PageLibrary" Spacing="16">
                    <TextBlock Text="Library Folders" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Moviebase monitors these folders for new movies."
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ListView x:Name="FolderList" MaxHeight="160" SelectionMode="Single"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                              CornerRadius="4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="12"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add Folder" Click="AddFolder_Click" />
                        <Button Content="Remove" Click="RemoveFolder_Click" />
                    </StackPanel>

                    <TextBlock Text="Import Settings" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
                    <ComboBox x:Name="ImportModeBox" Header="Default import mode" HorizontalAlignment="Stretch" SelectedIndex="0">
                        <ComboBoxItem Content="Symlink (saves space)" Tag="Symlink" />
                        <ComboBoxItem Content="Move to library" Tag="Move" />
                        <ComboBoxItem Content="Copy" Tag="Copy" />
                    </ComboBox>
                    <TextBox x:Name="LibraryRootBox" Header="Library root folder" PlaceholderText="Where imported movies go" />
                    <Button Content="Browse..." Click="BrowseLibraryRoot_Click" />

                    <TextBlock Text="File Extensions" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
                    <TextBox x:Name="ExtensionsBox" PlaceholderText=".mp4;.mkv;.avi;.m4v" />
                </StackPanel>

                <!-- TMDB Page -->
                <StackPanel x:Name="PageTmdb" Spacing="16" Visibility="Collapsed">
                    <TextBlock Text="TMDB Integration" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBox x:Name="ApiKeyBox" Header="API Key" PlaceholderText="Your TMDB API key" />
                    <HyperlinkButton Content="Get a free key from themoviedb.org"
                                     NavigateUri="https://www.themoviedb.org/settings/api" />
                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8" Padding="16,12" Margin="0,8,0,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Data Attribution" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                This product uses the TMDB API but is not endorsed or certified by TMDB.
                                All movie metadata and poster art provided by The Movie Database.
                            </TextBlock>
                            <HyperlinkButton Content="www.themoviedb.org" Padding="0"
                                             NavigateUri="https://www.themoviedb.org" FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Rename Page -->
                <StackPanel x:Name="PageRename" Spacing="16" Visibility="Collapsed">
                    <TextBlock Text="Rename Patterns" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Available tokens: {}{Title}, {}{Year}" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBox x:Name="FilePatternBox" Header="File rename pattern" PlaceholderText="{}{Title} ({Year})" />
                    <TextBox x:Name="FolderPatternBox" Header="Folder rename pattern" PlaceholderText="{}{Title} ({Year})" />
                    <ToggleSwitch x:Name="SwapTheToggle" Header="Move 'The' to end"
                                  OnContent="The Matrix → Matrix, The" OffContent="Keep as-is" />
                </StackPanel>

                <!-- About Page -->
                <StackPanel x:Name="PageAbout" Spacing="16" Visibility="Collapsed">
                    <TextBlock Text="About" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="48" Height="48" CornerRadius="8"
                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                            <TextBlock Text="M" FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Moviebase" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Version 2.1.0 — WinUI 3" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <ComboBox x:Name="ThemeBox" Header="Theme" Width="200" SelectedIndex="0">
                        <ComboBoxItem Content="System" Tag="System" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>

                    <HyperlinkButton Content="Source code on GitHub"
                                     NavigateUri="https://github.com/rasyidf/Moviebase" />
                    <HyperlinkButton Content="Terka — filename analyzer"
                                     NavigateUri="https://github.com/rasyidf/Trka" />
                    <TextBlock Text="© 2024–2026 rasyidf · MIT License" FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,12,0,0" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</ContentDialog>
