<ContentDialog
    x:Class="Moviebase.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="580" Width="480">
        <StackPanel Spacing="24">

            <!-- Library Folders -->
            <StackPanel Spacing="12">
                <TextBlock Text="Library Folders" FontWeight="SemiBold" />
                <TextBlock Text="Moviebase monitors these folders for movies. New files are automatically added to your library."
                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                <ListView x:Name="FolderList" MaxHeight="140" SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" VerticalAlignment="Center"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Add Folder" Click="AddFolder_Click">
                        <Button.Resources>
                            <x:Double x:Key="ButtonMinHeight">32</x:Double>
                        </Button.Resources>
                    </Button>
                    <Button Content="Remove" Click="RemoveFolder_Click">
                        <Button.Resources>
                            <x:Double x:Key="ButtonMinHeight">32</x:Double>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Import Settings -->
            <StackPanel Spacing="12">
                <TextBlock Text="Import" FontWeight="SemiBold" />
                <ComboBox x:Name="ImportModeBox" Header="Default import mode"
                          SelectedIndex="0" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Symlink (saves space, keeps original)" Tag="Symlink" />
                    <ComboBoxItem Content="Move (relocate file to library)" Tag="Move" />
                    <ComboBoxItem Content="Copy (duplicate file)" Tag="Copy" />
                </ComboBox>
                <TextBox x:Name="LibraryRootBox" Header="Library root folder"
                         PlaceholderText="Where imported movies are stored" />
                <Button Content="Browse..." Click="BrowseLibraryRoot_Click">
                    <Button.Resources>
                        <x:Double x:Key="ButtonMinHeight">32</x:Double>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <!-- TMDB API -->
            <StackPanel Spacing="12">
                <TextBlock Text="TMDB Integration" FontWeight="SemiBold" />
                <TextBox x:Name="ApiKeyBox" Header="API Key"
                         PlaceholderText="Enter your TMDB API key" />
                <HyperlinkButton Content="Get a free API key from themoviedb.org"
                                 NavigateUri="https://www.themoviedb.org/settings/api" />
            </StackPanel>

            <!-- File Settings -->
            <StackPanel Spacing="12">
                <TextBlock Text="File Scanning" FontWeight="SemiBold" />
                <TextBox x:Name="ExtensionsBox" Header="Movie Extensions"
                         PlaceholderText=".mp4;.mkv;.avi;.m4v" />
            </StackPanel>

            <!-- Rename Patterns -->
            <StackPanel Spacing="12">
                <TextBlock Text="Rename Patterns" FontWeight="SemiBold" />
                <TextBox x:Name="FilePatternBox" Header="File Pattern"
                         PlaceholderText="{}{Title} ({Year})" />
                <TextBox x:Name="FolderPatternBox" Header="Folder Pattern"
                         PlaceholderText="{}{Title} ({Year})" />
                <ToggleSwitch x:Name="SwapTheToggle" Header="Move 'The' to end"
                              OnContent="The Matrix → Matrix, The" OffContent="Keep as-is" />
            </StackPanel>

            <!-- About Section -->
            <StackPanel Spacing="12">
                <TextBlock Text="About" FontWeight="SemiBold" />
                <Grid ColumnSpacing="12" Padding="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE8B7;" FontSize="24" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Moviebase" FontWeight="SemiBold" />
                        <TextBlock Text="Version 2.1.0" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
                <HyperlinkButton Content="Source code on GitHub"
                                 NavigateUri="https://github.com/rasyidf/Moviebase" />

                <!-- TMDB Attribution -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        CornerRadius="8" Padding="16,12" Margin="0,4,0,0">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE946;" FontSize="16"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="Data Attribution" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            This product uses the TMDB API but is not endorsed or certified by TMDB.
                            All movie metadata and poster art provided by The Movie Database (TMDB).
                        </TextBlock>
                        <HyperlinkButton Content="www.themoviedb.org" Padding="0"
                                         NavigateUri="https://www.themoviedb.org" FontSize="12" />
                    </StackPanel>
                </Border>
                <TextBlock Text="© 2024–2026 rasyidf · MIT License" FontSize="11"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
